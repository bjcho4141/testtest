# utube-shorts-jp — 환경변수 템플릿
# 사용: cp .env.example .env.local 후 값 채우기
# 절대 .env.local / .env 를 커밋하지 말 것 (.gitignore 처리)

# ─────────────────────────────────────────
# Supabase (DB + Auth + Storage + Realtime)
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 — 클라이언트 번들 절대 금지
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────
# Kakao OAuth (Supabase Provider 측 + 백업)
# ─────────────────────────────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ─────────────────────────────────────────
# YouTube Data API v3
# 채널마다 별도 GCP 프로젝트 권고 (blast radius — PRD §13.1)
# ─────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# ─────────────────────────────────────────
# 토스페이먼츠 (PRD §16)
# 테스트 키: developers.tosspayments.com 회원가입 즉시 발급
# 키 접두사 test_ (clientKey: test_gck_... / secretKey: test_gsk_...)
# ─────────────────────────────────────────
TOSS_CLIENT_KEY=test_gck_
TOSS_SECRET_KEY=test_gsk_
# Webhook HMAC-SHA256 서명 검증용
TOSS_WEBHOOK_SECRET=

# ─────────────────────────────────────────
# AI / 음성 / 번역 (변환 파이프라인)
# ─────────────────────────────────────────
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─────────────────────────────────────────
# CLI 인증 — /api/cli/* (Bearer + IP allowlist)
# ─────────────────────────────────────────
# constant-time 비교용 shared secret (32+ bytes 권장)
CLI_SHARED_SECRET=
# CIDR 표기 (콤마 구분, 로컬 + 운영자 IP)
CLI_ALLOWED_IPS=127.0.0.1/32

# ─────────────────────────────────────────
# 슈퍼어드민 테스트 로그인 (DEV 전용)
# production 빌드 시 next.config.ts가 차단 (true이면 빌드 실패)
# ─────────────────────────────────────────
NEXT_PUBLIC_ALLOW_TEST_LOGIN=false

# ─────────────────────────────────────────
# Vercel (배포 시 자동 주입)
# ─────────────────────────────────────────
# VERCEL_ENV=development|preview|production
